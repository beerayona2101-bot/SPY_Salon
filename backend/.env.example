# SPY Salon Enterprise Backend Environment Configuration (Example)

# Server Port & Base URL
PORT=5000
BASE_URL=http://localhost:5000
NODE_ENV=production

# CORS Policy Allowed Origins (Use '*' or comma-separated domains)
CORS_ORIGIN=*
FRONTEND_URL=http://localhost:3000

# Database Connection (MongoDB Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/spysalon?retryWrites=true&w=majority

# Security & JWT Tokens
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here
JWT_REFRESH_EXPIRE=7d

# SMTP Nodemailer (For Email Notifications & Password Resets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="SPY Salon Admin <your-email@gmail.com>"

# Cloudinary CDN Image Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
